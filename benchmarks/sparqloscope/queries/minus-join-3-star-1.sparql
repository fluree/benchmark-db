# MINUS JOIN star of three large predicates with the largest sum of join sizes
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> PREFIX dblp: <https://dblp.org/rdf/schema#> SELECT (COUNT(*) AS ?count) WHERE { ?s dblp:signatureOrdinal ?o1 . ?s rdf:type ?o2 . MINUS { ?s dblp:signatureDblpName ?o3 . } }
