# GROUP BY with COUNT, for object but not sorted by object
PREFIX wdt: <http://www.wikidata.org/prop/direct/> PREFIX schema: <http://schema.org/> PREFIX p: <http://www.wikidata.org/prop/> SELECT ?o1 (COUNT(?s) AS ?count) { ?s wdt:P13046 ?o1 . ?s schema:description ?o2 . } GROUP BY ?o1 ORDER BY DESC(?count) LIMIT 10
